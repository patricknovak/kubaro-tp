---
import BaseLayout from './BaseLayout.astro';
const base = import.meta.env.BASE_URL;

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    author: string;
    category: string;
    readTime: string;
  };
}

const { frontmatter } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${frontmatter.title} | Kubaro TP`} description={frontmatter.description}>
  <article class="section-padding">
    <div class="max-w-3xl mx-auto">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-8">
        <a href={base} class="hover:text-navy-700">Home</a>
        <span class="mx-2">/</span>
        <a href={`${base}blog/`} class="hover:text-navy-700">Insights</a>
        <span class="mx-2">/</span>
        <span class="text-gray-700">{frontmatter.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-10">
        <span class="inline-block bg-gold-50 text-gold-700 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider mb-4">
          {frontmatter.category}
        </span>
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-navy-700 mb-4 leading-tight">
          {frontmatter.title}
        </h1>
        <div class="flex items-center gap-4 text-sm text-gray-500">
          <span>By {frontmatter.author}</span>
          <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
          <time datetime={frontmatter.date}>{formattedDate}</time>
          <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
          <span>{frontmatter.readTime}</span>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-navy-700 prose-a:text-gold-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-navy-800">
        <slot />
      </div>

      <!-- CTA -->
      <div class="mt-16 p-8 bg-navy-50 rounded-xl border border-navy-100 text-center">
        <h3 class="text-xl font-heading font-bold text-navy-700 mb-2">Need Transfer Pricing Help?</h3>
        <p class="text-gray-600 mb-4">Get a free initial consultation with 20 years of Canadian TP expertise.</p>
        <a href={`${base}contact/`} class="btn-primary">Book a Free Call</a>
      </div>
    </div>
  </article>
</BaseLayout>
