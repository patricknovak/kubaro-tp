---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Services | Kubaro Transfer Pricing Advisory">
  <!-- Hero Section -->
  <section class="gradient-navy text-white py-20 sm:py-32">
    <div class="container-narrow text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">Our Services</h1>
      <p class="text-lg sm:text-xl text-gray-200">
        Comprehensive transfer pricing solutions tailored to your business needs
      </p>
    </div>
  </section>

  <!-- Services Navigation -->
  <section class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="container-narrow">
      <div class="flex overflow-x-auto pb-0">
        <a href="#documentation" class="px-6 py-4 font-semibold text-navy-700 border-b-2 border-gold-500 whitespace-nowrap">Documentation</a>
        <a href="#benchmarking" class="px-6 py-4 font-semibold text-gray-600 border-b-2 border-transparent hover:border-gold-200 whitespace-nowrap">Benchmarking</a>
        <a href="#audit-defense" class="px-6 py-4 font-semibold text-gray-600 border-b-2 border-transparent hover:border-gold-200 whitespace-nowrap">Audit Defense</a>
        <a href="#policy" class="px-6 py-4 font-semibold text-gray-600 border-b-2 border-transparent hover:border-gold-200 whitespace-nowrap">Policy Design</a>
        <a href="#pillar-two" class="px-6 py-4 font-semibold text-gray-600 border-b-2 border-transparent hover:border-gold-200 whitespace-nowrap">Pillar Two</a>
        <a href="#ip-valuation" class="px-6 py-4 font-semibold text-gray-600 border-b-2 border-transparent hover:border-gold-200 whitespace-nowrap">IP Valuation</a>
      </div>
    </div>
  </section>

  <!-- TP Documentation Service -->
  <section id="documentation" class="section-padding bg-white border-b border-gray-100">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-navy-700 mb-6">Transfer Pricing Documentation</h2>
          <p class="text-gray-700 mb-6 leading-relaxed">
            Comprehensive transfer pricing documentation that meets CRA requirements and withstands regulatory scrutiny. We prepare both local files and master files that clearly establish the commercial rationale for your intercompany pricing.
          </p>
          <p class="text-gray-700 mb-8 leading-relaxed">
            Our documentation includes detailed economic analysis, benchmark studies where applicable, and a narrative that tells your commercial story. Every document is prepared with CRA audit defense in mind.
          </p>

          <h3 class="text-xl font-semibold text-navy-700 mb-4">What's Included</h3>
          <ul class="space-y-3 mb-8">
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Annual local files compliant with CRA standards</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Master file for multinational groups</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Economic analysis and functional assessment</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Contemporaneous pricing methodologies</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">CRA-ready formatting and organization</span>
            </li>
          </ul>

          <div class="mb-8">
            <span class="inline-block px-3 py-1 text-sm font-semibold text-navy-700 bg-navy-50 rounded-full">Ideal For: Single and multi-entity groups</span>
          </div>

          <a href={`${base}pricing`} class="btn-primary">View Pricing</a>
        </div>

        <div class="bg-gray-50 p-8 rounded-lg h-fit">
          <h3 class="text-lg font-semibold text-navy-700 mb-6">Documentation Process</h3>
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-gold-500 text-white rounded-full flex items-center justify-center font-semibold">1</span>
              <div>
                <h4 class="font-semibold text-navy-700 mb-1">Initial Assessment</h4>
                <p class="text-gray-600 text-sm">Review your group structure and intercompany transactions</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-gold-500 text-white rounded-full flex items-center justify-center font-semibold">2</span>
              <div>
                <h4 class="font-semibold text-navy-700 mb-1">Economic Analysis</h4>
                <p class="text-gray-600 text-sm">Conduct functional assessment and identify comparables</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-gold-500 text-white rounded-full flex items-center justify-center font-semibold">3</span>
              <div>
                <h4 class="font-semibold text-navy-700 mb-1">Documentation Preparation</h4>
                <p class="text-gray-600 text-sm">Prepare comprehensive local and master files</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-gold-500 text-white rounded-full flex items-center justify-center font-semibold">4</span>
              <div>
                <h4 class="font-semibold text-navy-700 mb-1">Review & Delivery</h4>
                <p class="text-gray-600 text-sm">Final review and delivery of CRA-ready documentation</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Benchmarking Studies Service -->
  <section id="benchmarking" class="section-padding bg-gray-50 border-b border-gray-100">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-navy-700 mb-6">Benchmarking Studies</h2>
          <p class="text-gray-700 mb-6 leading-relaxed">
            Rigorous benchmarking analysis that supports the arm's length nature of your intercompany pricing. We use multiple methodologies to identify comparable transactions and establish defensible pricing positions.
          </p>
          <p class="text-gray-700 mb-8 leading-relaxed">
            Our benchmarking studies include comprehensive database searches, financial analysis, and clear documentation of comparable companies and transactions. We consider your industry, geographic market, and transaction characteristics.
          </p>

          <h3 class="text-xl font-semibold text-navy-700 mb-4">What's Included</h3>
          <ul class="space-y-3 mb-8">
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Comparable company analysis</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">TNMM, CUP, and cost-plus methodologies</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Financial database searches (Thomson Reuters, Bloomberg, etc.)</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Range determination and interquartile analysis</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Sensitivity and scenario analysis</span>
            </li>
          </ul>

          <div class="mb-8">
            <span class="inline-block px-3 py-1 text-sm font-semibold text-navy-700 bg-navy-50 rounded-full">Ideal For: Companies with intercompany services or tangible asset transactions</span>
          </div>

          <a href={`${base}pricing`} class="btn-primary">View Pricing</a>
        </div>

        <div class="bg-white p-8 rounded-lg border border-gray-200 h-fit">
          <h3 class="text-lg font-semibold text-navy-700 mb-6">Methodologies We Use</h3>
          <div class="space-y-4">
            <div class="pb-4 border-b border-gray-200">
              <h4 class="font-semibold text-navy-700 mb-1">Comparable Uncontrolled Price (CUP)</h4>
              <p class="text-gray-600 text-sm">Direct comparison of prices charged between unrelated parties for similar transactions</p>
            </div>
            <div class="pb-4 border-b border-gray-200">
              <h4 class="font-semibold text-navy-700 mb-1">Transactional Net Margin Method (TNMM)</h4>
              <p class="text-gray-600 text-sm">Analysis of net profit margins relative to an appropriate base</p>
            </div>
            <div class="pb-4 border-b border-gray-200">
              <h4 class="font-semibold text-navy-700 mb-1">Cost Plus Method</h4>
              <p class="text-gray-600 text-sm">Markup on costs for services, manufacturing, or other activities</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-700 mb-1">Profit Split Method</h4>
              <p class="text-gray-600 text-sm">For highly integrated operations with unique contributions</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CRA Audit Defense Service -->
  <section id="audit-defense" class="section-padding bg-white border-b border-gray-100">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-navy-700 mb-6">CRA Audit Defense</h2>
          <p class="text-gray-700 mb-6 leading-relaxed">
            Expert defense and representation for CRA transfer pricing audits and reassessments. We work with you to respond to CRA requests, challenge assessments, and negotiate favorable resolutions.
          </p>
          <p class="text-gray-700 mb-8 leading-relaxed">
            Our audit defense strategy includes documentation review, CRA correspondence management, negotiation support, and representation at audit conferences. We draw on extensive experience with CRA audit procedures and dispute resolution.
          </p>

          <h3 class="text-xl font-semibold text-navy-700 mb-4">What's Included</h3>
          <ul class="space-y-3 mb-8">
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Audit file review and gap analysis</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">CRA information request responses</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Negotiation and dispute resolution support</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Audit conference representation</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Settlement and advance pricing agreement support</span>
            </li>
          </ul>

          <div class="mb-8">
            <span class="inline-block px-3 py-1 text-sm font-semibold text-navy-700 bg-navy-50 rounded-full">Ideal For: Companies under CRA audit or reassessment</span>
          </div>

          <a href={`${base}contact`} class="btn-primary">Schedule Consultation</a>
        </div>

        <div class="bg-gold-50 p-8 rounded-lg h-fit">
          <h3 class="text-lg font-semibold text-navy-700 mb-6">Why Choose Kubaro for Audit Defense?</h3>
          <ul class="space-y-4">
            <li class="flex gap-3">
              <span class="text-gold-500 font-bold">✓</span>
              <span class="text-gray-700"><strong>CRA Experience:</strong> Extensive background negotiating with CRA auditors and dispute resolution specialists</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gold-500 font-bold">✓</span>
              <span class="text-gray-700"><strong>Strategic Approach:</strong> Develop defensible positions grounded in economic reality and OECD guidance</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gold-500 font-bold">✓</span>
              <span class="text-gray-700"><strong>Cost-Effective:</strong> Efficient resolution without Big 4 budgets or unnecessary escalation</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gold-500 font-bold">✓</span>
              <span class="text-gray-700"><strong>Client Advocacy:</strong> We fight for your interests while maintaining productive relationships with CRA</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Policy Design Service -->
  <section id="policy" class="section-padding bg-gray-50 border-b border-gray-100">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-navy-700 mb-6">Policy Design</h2>
          <p class="text-gray-700 mb-6 leading-relaxed">
            Develop comprehensive transfer pricing policies aligned with OECD Transfer Pricing Guidelines and Canadian tax law. We design policies that reflect your business operations while minimizing transfer pricing risk.
          </p>
          <p class="text-gray-700 mb-8 leading-relaxed">
            A well-designed transfer pricing policy provides clear guidance, supports documentation, and demonstrates to tax authorities that your pricing is commercially reasonable and defensible.
          </p>

          <h3 class="text-xl font-semibold text-navy-700 mb-4">What's Included</h3>
          <ul class="space-y-3 mb-8">
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Group structure and transaction mapping</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Functional analysis and risk assessment</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Pricing methodology selection and documentation</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">OECD-aligned policy document</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">Implementation guidance and staff training</span>
            </li>
          </ul>

          <div class="mb-8">
            <span class="inline-block px-3 py-1 text-sm font-semibold text-navy-700 bg-navy-50 rounded-full">Ideal For: Multinational groups establishing transfer pricing governance</span>
          </div>

          <a href={`${base}pricing`} class="btn-primary">View Pricing</a>
        </div>

        <div class="bg-white p-8 rounded-lg border border-gray-200 h-fit">
          <h3 class="text-lg font-semibold text-navy-700 mb-6">Policy Elements</h3>
          <div class="space-y-4">
            <div>
              <h4 class="font-semibold text-navy-700 mb-2">Governance & Approval</h4>
              <p class="text-gray-600 text-sm">Board-level approval process and ongoing review procedures</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-700 mb-2">Transaction Documentation</h4>
              <p class="text-gray-600 text-sm">Clear requirements for documenting intercompany transactions</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-700 mb-2">Pricing Authority</h4>
              <p class="text-gray-600 text-sm">Who sets prices and approval authorities by transaction type</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-700 mb-2">Transfer Adjustments</h4>
              <p class="text-gray-600 text-sm">Process for handling adjustments to align with arm's length principle</p>
            </div>
            <div>
              <h4 class="font-semibold text-navy-700 mb-2">Dispute Resolution</h4>
              <p class="text-gray-600 text-sm">Procedures for resolving intragroup transfer pricing disputes</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar Two Service -->
  <section id="pillar-two" class="section-padding bg-white border-b border-gray-100">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-navy-700 mb-6">Pillar Two Advisory</h2>
          <p class="text-gray-700 mb-6 leading-relaxed">
            Navigate the complex landscape of OECD Pillar Two and the Global Minimum Tax regime. We provide guidance on application to your group, GloBE income calculations, and filing requirements in Canada and the US.
          </p>
          <p class="text-gray-700 mb-8 leading-relaxed">
            With ongoing regulatory developments and implementation challenges, strategic planning and expert guidance are essential. We help you understand your Pillar Two exposure and optimize your tax position within the rules.
          </p>

          <h3 class="text-xl font-semibold text-navy-700 mb-4">What's Included</h3>
          <ul class="space-y-3 mb-8">
