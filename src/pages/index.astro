---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home | Kubaro Transfer Pricing Advisory">
  <!-- Hero Section -->
  <section class="gradient-navy text-white py-20 sm:py-32">
    <div class="container-narrow text-center">
      <h1 class="text-4xl sm:text-6xl font-bold mb-6 leading-tight">
        Transfer Pricing.<br />Simplified.<br />Powered by AI.
      </h1>
      <p class="text-lg sm:text-xl mb-8 text-gray-200 max-w-2xl mx-auto">
        20 years of transfer pricing expertise combined with cutting-edge AI efficiency.
        We deliver enterprise-grade analysis at a fraction of Big 4 costs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}contact`} class="btn-primary">
          Book a Call
        </a>
        <a href={`${base}services`} class="btn-secondary">
          Explore Services
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar Section -->
  <section class="bg-white py-12 border-b border-gray-200">
    <div class="container-narrow">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-navy-700">20+</div>
          <p class="text-gray-600">Years Experience</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-navy-700">200+</div>
          <p class="text-gray-600">Projects Completed</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-gold-500">CA & US</div>
          <p class="text-gray-600">Markets Served</p>
        </div>
        <div>
          <div class="text-3xl font-bold text-navy-700">AI-Powered</div>
          <p class="text-gray-600">Workflows</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">Our Services</h2>
        <p class="text-gray-600 text-lg">Comprehensive transfer pricing solutions built for modern businesses</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- TP Documentation -->
        <a href={`${base}services#documentation`} class="card hover:shadow-lg transition">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">TP Documentation</h3>
          <p class="text-gray-600 text-sm mb-4">Annual local files and master files compliant with CRA requirements</p>
        </a>

        <!-- Benchmarking -->
        <a href={`${base}services#benchmarking`} class="card hover:shadow-lg transition">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">Benchmarking Studies</h3>
          <p class="text-gray-600 text-sm mb-4">TNMM, comparable uncontrolled price, and cost-plus analysis</p>
        </a>

        <!-- CRA Audit Defense -->
        <a href={`${base}services#audit-defense`} class="card hover:shadow-lg transition">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">CRA Audit Defense</h3>
          <p class="text-gray-600 text-sm mb-4">Expert representation and defense strategy for CRA disputes</p>
        </a>

        <!-- Policy Design -->
        <a href={`${base}services#policy`} class="card hover:shadow-lg transition">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">Policy Design</h3>
          <p class="text-gray-600 text-sm mb-4">Develop robust transfer pricing policies aligned with OECD standards</p>
        </a>

        <!-- Pillar Two -->
        <a href={`${base}services#pillar-two`} class="card hover:shadow-lg transition">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">Pillar Two Advisory</h3>
          <p class="text-gray-600 text-sm mb-4">Global minimum tax compliance and OECD Pillar Two implementation</p>
        </a>

        <!-- IP Valuation -->
        <a href={`${base}services#ip-valuation`} class="card hover:shadow-lg transition">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">IP Valuation</h3>
          <p class="text-gray-600 text-sm mb-4">Intangible asset and intellectual property valuation analysis</p>
        </a>
      </div>

      <div class="text-center mt-12">
        <a href={`${base}services`} class="btn-primary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Why Kubaro Section -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">Why Kubaro</h2>
        <p class="text-gray-600 text-lg">What sets us apart from traditional consulting</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m7 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">Deep Expertise</h3>
          <p class="text-gray-600">20 years of transfer pricing experience with companies across Canada and the US, from SMEs to multinationals.</p>
        </div>

        <div class="bg-white p-8 rounded-lg">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">AI-Powered Efficiency</h3>
          <p class="text-gray-600">Our AI workflows reduce analysis time by 60%, delivering quality results faster and more cost-effectively.</p>
        </div>

        <div class="bg-white p-8 rounded-lg">
          <div class="flex items-center justify-center w-12 h-12 bg-gold-50 rounded-lg mb-4">
            <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">Transparent Pricing</h3>
          <p class="text-gray-600">Fixed-fee engagements with clear scope. No surprises, no hidden costs, no Big 4 markups.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner Section -->
  <section class="bg-gold-50 py-16">
    <div class="container-narrow text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-navy-700 mb-6">
        Not Sure About Your TP Compliance?
      </h2>
      <p class="text-gray-700 mb-8 text-lg">
        Take our free 5-minute risk assessment to identify compliance gaps and opportunities.
      </p>
      <a href={`${base}risk-assessment`} class="btn-primary">Start Risk Assessment</a>
    </div>
  </section>

  <!-- Latest Insights Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">Latest Insights</h2>
        <p class="text-gray-600 text-lg">Stay updated on regulatory changes and transfer pricing strategy</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <!-- Blog Card 1 -->
        <a href={`${base}blog/budget-2025-transfer-pricing-changes`} class="card hover:shadow-lg transition">
          <div class="mb-4">
            <span class="inline-block px-3 py-1 text-xs font-semibold text-gold-500 bg-gold-50 rounded-full">Regulatory Updates</span>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">Budget 2025: Transfer Pricing Changes Explained</h3>
          <p class="text-gray-600 text-sm mb-4">Key changes to Canadian transfer pricing rules and what they mean for your compliance strategy.</p>
          <div class="flex items-center justify-between text-xs text-gray-500">
            <span>Mar 5, 2025</span>
            <span>5 min read</span>
          </div>
        </a>

        <!-- Blog Card 2 -->
        <a href={`${base}blog/how-to-prepare-tp-documentation-canada`} class="card hover:shadow-lg transition">
          <div class="mb-4">
            <span class="inline-block px-3 py-1 text-xs font-semibold text-gold-500 bg-gold-50 rounded-full">How-To Guides</span>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">How to Prepare TP Documentation for CRA</h3>
          <p class="text-gray-600 text-sm mb-4">Step-by-step guide to preparing compliant transfer pricing documentation that passes CRA review.</p>
          <div class="flex items-center justify-between text-xs text-gray-500">
            <span>Mar 1, 2025</span>
            <span>8 min read</span>
          </div>
        </a>

        <!-- Blog Card 3 -->
        <a href={`${base}blog/cra-audit-defense-strategies`} class="card hover:shadow-lg transition">
          <div class="mb-4">
            <span class="inline-block px-3 py-1 text-xs font-semibold text-gold-500 bg-gold-50 rounded-full">Industry Focus</span>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-2">CRA Audit Defense: Proven Strategies</h3>
          <p class="text-gray-600 text-sm mb-4">How to effectively defend your transfer pricing positions during CRA audits and reassessments.</p>
          <div class="flex items-center justify-between text-xs text-gray-500">
            <span>Feb 25, 2025</span>
            <span>6 min read</span>
          </div>
        </a>
      </div>

      <div class="text-center">
        <a href={`${base}blog`} class="btn-secondary">Read All Insights</a>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="gradient-navy text-white py-16">
    <div class="container-narrow text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">
        Ready to Modernize Your Transfer Pricing?
      </h2>
      <p class="text-lg mb-8 text-gray-200">
        Let's discuss how Kubaro can help your business achieve efficient, compliant transfer pricing.
      </p>
      <a href={`${base}contact`} class="btn-primary">Schedule Your Consultation</a>
    </div>
  </section>
</BaseLayout>
