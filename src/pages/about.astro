---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About | Kubaro Transfer Pricing Advisory">
  <!-- Hero Section -->
  <section class="gradient-navy text-white py-20 sm:py-32">
    <div class="container-narrow text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">Meet James Crow</h1>
      <p class="text-lg sm:text-xl text-gray-200">
        Founder & Principal Consultant, Kubaro Transfer Pricing Advisory
      </p>
    </div>
  </section>

  <!-- Professional Bio Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="bg-gray-200 w-full h-96 rounded-lg flex items-center justify-center text-gray-400">
            <span class="text-lg">[Professional Photo]</span>
          </div>
        </div>
        <div>
          <h2 class="text-3xl font-bold text-navy-700 mb-6">A 20-Year Transfer Pricing Veteran</h2>
          <p class="text-gray-700 mb-4 leading-relaxed">
            James Crow brings over two decades of transfer pricing expertise to every engagement. Throughout his career, he has worked with companies across Canada and the United States, from ambitious small and medium enterprises to complex multinationals with operations spanning multiple continents.
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            His experience spans both Big 4 consulting firms and boutique advisory practices, giving him a unique perspective on what works in the real world. James has guided clients through CRA audits, designed robust transfer pricing policies, and delivered documentation that has consistently withstood regulatory scrutiny.
          </p>
          <p class="text-gray-700 leading-relaxed">
            What drives James is a commitment to making enterprise-grade transfer pricing analysis accessible to businesses of all sizes, without the premium price tag of traditional Big 4 consulting.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="section-padding bg-gold-50">
    <div class="container-narrow">
      <div class="bg-white rounded-lg p-8 sm:p-12 border-l-4 border-gold-500">
        <h2 class="text-2xl sm:text-3xl font-bold text-navy-700 mb-6">The Kubaro Philosophy</h2>
        <p class="text-lg text-gray-700 leading-relaxed italic">
          "I founded Kubaro because I believe transfer pricing shouldn't require a Big 4 budget. AI lets us deliver the same quality analysis in less time, at a fraction of the cost. Transfer pricing is complex, yes—but it doesn't have to be expensive. That's what we're changing."
        </p>
      </div>
    </div>
  </section>

  <!-- What Makes Kubaro Different Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">What Makes Kubaro Different</h2>
        <p class="text-gray-600 text-lg">Four core pillars that define our approach</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Pillar 1 -->
        <div class="bg-gray-50 p-8 rounded-lg">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-4">Deep Expertise</h3>
          <p class="text-gray-700">
            More than 20 years of specialized transfer pricing experience. We've seen it all and know how to navigate complex scenarios with confidence.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div class="bg-gray-50 p-8 rounded-lg">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5h.01" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-4">AI-First Approach</h3>
          <p class="text-gray-700">
            We leverage cutting-edge AI workflows to accelerate analysis and reduce costs, without compromising quality or accuracy.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div class="bg-gray-50 p-8 rounded-lg">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.856-1.487M15 10h.01M11 10h.01M7 10h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-4">Client-Centric</h3>
          <p class="text-gray-700">
            We work closely with you to understand your business, objectives, and constraints. Your success is our success.
          </p>
        </div>

        <!-- Pillar 4 -->
        <div class="bg-gray-50 p-8 rounded-lg">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-4">Results-Driven</h3>
          <p class="text-gray-700">
            We focus on deliverables that matter: compliant documentation, defensible positions, and measurable business outcomes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Career Timeline Section -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">Career Journey</h2>
        <p class="text-gray-600 text-lg">A timeline of experience and expertise</p>
      </div>

      <div class="max-w-3xl mx-auto">
        <!-- Timeline Item 1 -->
        <div class="flex gap-6 mb-12">
          <div class="flex flex-col items-center">
            <div class="w-4 h-4 bg-gold-500 rounded-full mt-2"></div>
            <div class="w-1 h-24 bg-gold-200"></div>
          </div>
          <div>
            <h4 class="text-lg font-semibold text-navy-700">2004-2010: Big 4 Foundation</h4>
            <p class="text-gray-600">Started career with a major international consulting firm, developing expertise across transfer pricing methodologies, documentation, and audit defense.</p>
          </div>
        </div>

        <!-- Timeline Item 2 -->
        <div class="flex gap-6 mb-12">
          <div class="flex flex-col items-center">
            <div class="w-4 h-4 bg-gold-500 rounded-full mt-2"></div>
            <div class="w-1 h-24 bg-gold-200"></div>
          </div>
          <div>
            <h4 class="text-lg font-semibold text-navy-700">2010-2018: Boutique Leadership</h4>
            <p class="text-gray-600">Led transfer pricing advisory at a boutique firm, managing complex engagements for multinational enterprises and building a reputation for pragmatic, defensible analysis.</p>
          </div>
        </div>

        <!-- Timeline Item 3 -->
        <div class="flex gap-6 mb-12">
          <div class="flex flex-col items-center">
            <div class="w-4 h-4 bg-gold-500 rounded-full mt-2"></div>
            <div class="w-1 h-24 bg-gold-200"></div>
          </div>
          <div>
            <h4 class="text-lg font-semibold text-navy-700">2018-2023: Independent Practice</h4>
            <p class="text-gray-600">Built independent practice serving mid-market and growth-stage companies seeking high-quality transfer pricing advice without Big 4 costs.</p>
          </div>
        </div>

        <!-- Timeline Item 4 -->
        <div class="flex gap-6">
          <div class="flex flex-col items-center">
            <div class="w-4 h-4 bg-gold-500 rounded-full mt-2"></div>
          </div>
          <div>
            <h4 class="text-lg font-semibold text-navy-700">2024-Present: Kubaro Advisory</h4>
            <p class="text-gray-600">Founded Kubaro to combine two decades of transfer pricing expertise with AI-powered workflows, making enterprise-quality analysis accessible to all.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-6">
        Let's Talk About Your Transfer Pricing
      </h2>
      <p class="text-lg text-gray-600 mb-8">
        Ready to work with someone who understands your business and gets results?
      </p>
      <a href={`${base}contact`} class="btn-primary">Schedule a Consultation</a>
    </div>
  </section>
</BaseLayout>
