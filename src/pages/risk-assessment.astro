---
import BaseLayout from '../layouts/BaseLayout.astro';
import RiskAssessment from '../tools/RiskAssessment.jsx';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Risk Assessment | Kubaro Transfer Pricing Advisory">
  <!-- Hero Section -->
  <section class="gradient-navy text-white py-20 sm:py-32">
    <div class="container-narrow text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">
        How Strong Is Your Transfer Pricing?
      </h1>
      <p class="text-lg sm:text-xl text-gray-200">
        Take our free 5-minute assessment to identify compliance gaps and opportunities
      </p>
    </div>
  </section>

  <!-- Assessment Tool Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <RiskAssessment client:load />
      </div>
    </div>
  </section>

  <!-- Disclaimer Section -->
  <section class="section-padding bg-gray-50 border-t border-gray-200">
    <div class="container-narrow max-w-3xl">
      <h2 class="text-2xl font-bold text-navy-700 mb-6">About This Assessment</h2>

      <div class="space-y-4 text-gray-700">
        <p>
          This risk assessment is provided for educational and informational purposes only and does not constitute professional tax or legal advice. The questions and scoring are designed to help you identify potential transfer pricing compliance issues, but the results should not be considered a comprehensive transfer pricing analysis.
        </p>

        <p>
          Your specific transfer pricing obligations depend on multiple factors including:
        </p>
        <ul class="list-disc list-inside space-y-2 ml-2">
          <li>Your corporate structure and jurisdiction of operations</li>
          <li>The nature and volume of intercompany transactions</li>
          <li>Your total annual revenues and profits</li>
          <li>Specific CRA guidance and rulings applicable to your business</li>
          <li>Recent changes in tax law and regulations</li>
        </ul>

        <p>
          For a comprehensive transfer pricing assessment tailored to your specific situation, we recommend consulting with a qualified transfer pricing advisor. Kubaro can provide a detailed analysis and documentation plan based on a thorough review of your business operations.
        </p>

        <p class="font-semibold">
          This assessment result should not be relied upon as a substitute for professional advice.
        </p>
      </div>
    </div>
  </section>

  <!-- Next Steps Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-700 mb-8">What to Do Next</h2>

        <div class="space-y-6">
          <!-- Step 1 -->
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-gold-50 text-gold-500 font-bold text-lg">
                1
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-navy-700 mb-2">Review Your Results</h3>
              <p class="text-gray-700">
                Look at your assessment results to identify areas of concern. High-risk areas typically involve significant intercompany transactions, intangible assets, or complex group structures.
              </p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-gold-50 text-gold-500 font-bold text-lg">
                2
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-navy-700 mb-2">Assess Your Priorities</h3>
              <p class="text-gray-700">
                Based on your risk level, prioritize transfer pricing documentation, policy design, or audit defense. If you're already under audit, that becomes the immediate priority.
              </p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-gold-50 text-gold-500 font-bold text-lg">
                3
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-navy-700 mb-2">Schedule a Consultation</h3>
              <p class="text-gray-700">
                Connect with our team to discuss your specific situation, transfer pricing obligations, and engagement options. We can provide a customized roadmap and pricing proposal.
              </p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-gold-50 text-gold-500 font-bold text-lg">
                4
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-navy-700 mb-2">Get Expert Support</h3>
              <p class="text-gray-700">
                Work with Kubaro to develop transfer pricing documentation, policies, and strategies that minimize risk and ensure CRA compliance.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-gold-50">
    <div class="container-narrow max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-navy-700 mb-6">
        Let's Strengthen Your Transfer Pricing
      </h2>
      <p class="text-gray-700 text-lg mb-8">
        Schedule a free consultation with our team to develop a transfer pricing strategy tailored to your business.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}contact`} class="btn-primary">Schedule Consultation</a>
        <a href={`${base}services`} class="btn-secondary">View Services</a>
      </div>
    </div>
  </section>

  <!-- Resources Section -->
  <section class="section-padding bg-white border-t border-gray-200">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-navy-700 mb-4">Related Resources</h2>
        <p class="text-gray-600">Learn more about transfer pricing compliance</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <a href={`${base}resources`} class="card hover:shadow-lg transition">
          <h3 class="text-lg font-semibold text-navy-700 mb-2">Free Resources</h3>
          <p class="text-gray-600 text-sm">Download checklists, guides, and templates for transfer pricing compliance.</p>
        </a>

        <a href={`${base}services`} class="card hover:shadow-lg transition">
          <h3 class="text-lg font-semibold text-navy-700 mb-2">Our Services</h3>
          <p class="text-gray-600 text-sm">Explore our full range of transfer pricing advisory and documentation services.</p>
        </a>

        <a href={`${base}blog`} class="card hover:shadow-lg transition">
          <h3 class="text-lg font-semibold text-navy-700 mb-2">Latest Insights</h3>
          <p class="text-gray-600 text-sm">Read our latest articles on transfer pricing, regulatory updates, and best practices.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
