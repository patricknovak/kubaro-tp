---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact | Kubaro Transfer Pricing Advisory">
  <!-- Hero Section -->
  <section class="gradient-navy text-white py-20 sm:py-32">
    <div class="container-narrow text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">Let's Talk Transfer Pricing</h1>
      <p class="text-lg sm:text-xl text-gray-200">
        We're ready to discuss your transfer pricing needs and help you find the right solution.
      </p>
    </div>
  </section>

  <!-- Contact Content Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-navy-700 mb-8">Send us a Message</h2>

          <form class="space-y-6" onsubmit="return false;">
            <!-- Name Field -->
            <div>
              <label class="block text-sm font-semibold text-navy-700 mb-2">Full Name</label>
              <input
                type="text"
                placeholder="Your name"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-gold-500 focus:outline-none focus:ring-1 focus:ring-gold-500"
                required
              />
            </div>

            <!-- Email Field -->
            <div>
              <label class="block text-sm font-semibold text-navy-700 mb-2">Email Address</label>
              <input
                type="email"
                placeholder="your@email.com"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-gold-500 focus:outline-none focus:ring-1 focus:ring-gold-500"
                required
              />
            </div>

            <!-- Company Field -->
            <div>
              <label class="block text-sm font-semibold text-navy-700 mb-2">Company Name</label>
              <input
                type="text"
                placeholder="Your company"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-gold-500 focus:outline-none focus:ring-1 focus:ring-gold-500"
              />
            </div>

            <!-- Phone Field -->
            <div>
              <label class="block text-sm font-semibold text-navy-700 mb-2">Phone Number</label>
              <input
                type="tel"
                placeholder="+1 (555) 000-0000"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-gold-500 focus:outline-none focus:ring-1 focus:ring-gold-500"
              />
            </div>

            <!-- Service Interest Dropdown -->
            <div>
              <label class="block text-sm font-semibold text-navy-700 mb-2">Service of Interest</label>
              <select class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-gold-500 focus:outline-none focus:ring-1 focus:ring-gold-500">
                <option value="">Select a service</option>
                <option value="documentation">TP Documentation</option>
                <option value="benchmarking">Benchmarking Studies</option>
                <option value="audit-defense">CRA Audit Defense</option>
                <option value="policy-design">Policy Design</option>
                <option value="pillar-two">Pillar Two Advisory</option>
                <option value="ip-valuation">IP Valuation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Message Field -->
            <div>
              <label class="block text-sm font-semibold text-navy-700 mb-2">Message</label>
              <textarea
                placeholder="Tell us about your transfer pricing needs and any questions you have."
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-gold-500 focus:outline-none focus:ring-1 focus:ring-gold-500"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              onclick="alert('Thank you for reaching out! We will respond within 24 hours.')"
              class="btn-primary w-full"
            >
              Send Message
            </button>
          </form>

          <p class="text-xs text-gray-500 mt-4">
            We'll respond to your inquiry within 24 hours during business days.
          </p>
        </div>

        <!-- Contact Information -->
        <div>
          <h2 class="text-2xl font-bold text-navy-700 mb-8">Get in Touch</h2>

          <!-- Contact Details -->
          <div class="space-y-8 mb-12">
            <!-- Email -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Email</h3>
              <a href="mailto:hello@kubarotp.com" class="text-lg font-semibold text-gold-500 hover:text-gold-600">
                hello@kubarotp.com
              </a>
              <p class="text-gray-600 text-sm mt-1">Primary contact for all inquiries</p>
            </div>

            <!-- Phone -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Phone</h3>
              <a href="tel:+14165551234" class="text-lg font-semibold text-gold-500 hover:text-gold-600">
                +1 (416) 555-1234
              </a>
              <p class="text-gray-600 text-sm mt-1">Monday to Friday, 9 AM – 5 PM EST</p>
            </div>

            <!-- Locations -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Locations</h3>
              <div class="space-y-3">
                <div>
                  <p class="font-semibold text-navy-700">Toronto, Canada</p>
                  <p class="text-gray-600 text-sm">123 King St W, Toronto, ON</p>
                </div>
                <div>
                  <p class="font-semibold text-navy-700">Vancouver, Canada</p>
                  <p class="text-gray-600 text-sm">456 Granville St, Vancouver, BC</p>
                </div>
              </div>
            </div>
          </div>

          <!-- AI Receptionist Note -->
          <div class="bg-gold-50 p-6 rounded-lg border border-gold-200">
            <h3 class="text-lg font-semibold text-navy-700 mb-3">24/7 AI Assistant</h3>
            <p class="text-gray-700 text-sm leading-relaxed">
              Our AI-powered assistant is available around the clock to answer initial questions about our services, pricing, and transfer pricing topics. For detailed consultations with our expert team, schedule a call during business hours.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect Section -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">What to Expect</h2>
        <p class="text-gray-600 text-lg">Our engagement process</p>
      </div>

      <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="text-center">
          <div class="flex items-center justify-center w-16 h-16 bg-gold-500 text-white rounded-full mx-auto mb-6 text-2xl font-bold">
            1
          </div>
          <h3 class="text-xl font-bold text-navy-700 mb-3">Free Consultation</h3>
          <p class="text-gray-700">
            We'll schedule a free 30-minute call to understand your business, transfer pricing structure, and specific needs.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center">
          <div class="flex items-center justify-center w-16 h-16 bg-gold-500 text-white rounded-full mx-auto mb-6 text-2xl font-bold">
            2
          </div>
          <h3 class="text-xl font-bold text-navy-700 mb-3">Proposal & Scope</h3>
          <p class="text-gray-700">
            We'll provide a customized proposal with fixed pricing, clear scope, and timeline within 48 hours of our call.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center">
          <div class="flex items-center justify-center w-16 h-16 bg-gold-500 text-white rounded-full mx-auto mb-6 text-2xl font-bold">
            3
          </div>
          <h3 class="text-xl font-bold text-navy-700 mb-3">Engagement Begins</h3>
          <p class="text-gray-700">
            Once you approve the proposal, we'll kick off the engagement with regular communication and transparent progress updates.
          </p>
        </div>
      </div>

      <div class="mt-12 max-w-2xl mx-auto bg-blue-50 p-8 rounded-lg border border-blue-200 text-center">
        <svg class="w-8 h-8 text-blue-500 mx-auto mb-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 5v8a2 2 0 01-2 2h-5l-5 4v-4H4a2 2 0 01-2-2V5a2 2 0 012-2h12a2 2 0 012 2zm-11-1a1 1 0 100 2h2a1 1 0 100-2H7zm2 4a1 1 0 100 2h2a1 1 0 100-2H9z" clip-rule="evenodd" />
        </svg>
        <h4 class="text-lg font-semibold text-blue-900 mb-2">No Pressure, No Surprises</h4>
        <p class="text-blue-800 text-sm">
          We work at your pace. Once a proposal is agreed, you know exactly what to expect in terms of cost and timeline. Fixed pricing means no surprises.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ - Contact Related -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-navy-700 mb-4">Contact FAQs</h2>
      </div>

      <div class="max-w-3xl mx-auto space-y-6">
        <!-- FAQ 1 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            How quickly can you respond to my inquiry?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4">
            We aim to respond to all inquiries within 24 hours during business days. Urgent requests or referrals may receive faster responses. You can also call our phone line to speak with an AI assistant immediately.
          </p>
        </details>

        <!-- FAQ 2 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            Is the initial consultation really free?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4">
            Yes, completely free. The 30-minute consultation is our way of understanding your situation and determining how we can help. There's no obligation to move forward after the consultation.
          </p>
        </details>

        <!-- FAQ 3 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            Can we meet in person or do we work remotely?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4">
            We offer both options. We can meet in person at our Toronto or Vancouver offices, or conduct all consultations and engagements remotely via video conference and email. Most of our clients prefer the flexibility of remote engagement.
          </p>
        </details>

        <!-- FAQ 4 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            What information should I prepare for the consultation?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4">
            Come prepared with an overview of your group structure, the nature of intercompany transactions, your annual revenues, and any specific compliance concerns. You don't need detailed documentation for the initial call—that can be discussed during the consultation.
          </p>
        </details>

        <!-- FAQ 5 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            How do I know if you're the right fit for my company?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4">
            That's exactly what the consultation is for. We'll discuss your needs, answer your questions, and be honest about whether Kubaro is the right partner. We'd rather have a transparent conversation upfront than take on an engagement that isn't the right fit.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-padding bg-gradient-navy text-white">
    <div class="container-narrow text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">Ready to Get Started?</h2>
      <p class="text-lg mb-8 text-gray-200">
        Schedule your free consultation today and let's discuss your transfer pricing needs.
      </p>
      <a href={`${base}contact`} class="btn-primary">Schedule Consultation</a>
    </div>
  </section>
</BaseLayout>
