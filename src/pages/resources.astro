---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Resources | Kubaro Transfer Pricing Advisory">
  <!-- Hero Section -->
  <section class="gradient-navy text-white py-20 sm:py-32">
    <div class="container-narrow text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6">Free Resources</h1>
      <p class="text-lg sm:text-xl text-gray-200">
        Essential guides and templates to strengthen your transfer pricing compliance
      </p>
    </div>
  </section>

  <!-- Downloads Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">Download Center</h2>
        <p class="text-gray-600 text-lg">Free tools and guides to help your business</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Resource 1 -->
        <div class="card border-2 border-gold-100 hover:border-gold-500 transition">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">Canadian TP Documentation Checklist</h3>
          <p class="text-gray-600 mb-6">
            Comprehensive checklist of all documentation requirements for CRA-compliant transfer pricing files. Includes local file, master file, and contemporaneous documentation requirements.
          </p>
          <p class="text-sm text-gray-500 mb-6">PDF • 2.4 MB</p>
          <button
            onclick="alert('Download ready: Canadian TP Documentation Checklist.pdf')"
            class="btn-primary w-full"
          >
            Download Free
          </button>
        </div>

        <!-- Resource 2 -->
        <div class="card border-2 border-gold-100 hover:border-gold-500 transition">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">Budget 2025 Impact Summary</h3>
          <p class="text-gray-600 mb-6">
            Executive summary of transfer pricing changes in Budget 2025, including effective dates, compliance deadlines, and strategic implications for your business.
          </p>
          <p class="text-sm text-gray-500 mb-6">PDF • 1.8 MB</p>
          <button
            onclick="alert('Download ready: Budget 2025 Impact Summary.pdf')"
            class="btn-primary w-full"
          >
            Download Free
          </button>
        </div>

        <!-- Resource 3 -->
        <div class="card border-2 border-gold-100 hover:border-gold-500 transition">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">CRA Audit Preparation Guide</h3>
          <p class="text-gray-600 mb-6">
            Step-by-step guide to preparing for a CRA transfer pricing audit, including information requests, documentation organization, and response strategy.
          </p>
          <p class="text-sm text-gray-500 mb-6">PDF • 3.1 MB</p>
          <button
            onclick="alert('Download ready: CRA Audit Preparation Guide.pdf')"
            class="btn-primary w-full"
          >
            Download Free
          </button>
        </div>

        <!-- Resource 4 -->
        <div class="card border-2 border-gold-100 hover:border-gold-500 transition">
          <div class="flex items-center justify-center w-14 h-14 bg-gold-50 rounded-lg mb-6">
            <svg class="w-7 h-7 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">Intercompany Agreement Template</h3>
          <p class="text-gray-600 mb-6">
            Customizable template for documenting intercompany agreements and pricing decisions. Includes service agreements, management fee structures, and IP licensing templates.
          </p>
          <p class="text-sm text-gray-500 mb-6">DOCX • 4.2 MB</p>
          <button
            onclick="alert('Download ready: Intercompany Agreement Template.docx')"
            class="btn-primary w-full"
          >
            Download Free
          </button>
        </div>
      </div>

      <div class="text-center p-8 bg-gold-50 rounded-lg border border-gold-200">
        <p class="text-gray-700">
          All resources are provided free of charge. No registration required. Download and customize for your needs.
        </p>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup Section -->
  <section id="newsletter" class="section-padding bg-white">
    <div class="container-narrow max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-navy-700 mb-4">Get More Resources</h2>
        <p class="text-gray-700 text-lg">
          Subscribe to our newsletter for exclusive guides, templates, and transfer pricing insights.
        </p>
      </div>

      <form class="flex flex-col sm:flex-row gap-3" onsubmit="return false;">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 px-4 py-3 rounded-lg border border-gray-300 focus:border-gold-500 focus:outline-none"
          required
        />
        <button
          type="submit"
          class="btn-primary whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>

      <p class="text-xs text-gray-600 text-center mt-4">
        We respect your privacy. Unsubscribe at any time.
      </p>
    </div>
  </section>

  <!-- Tools Section -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">Transfer Pricing Tools</h2>
        <p class="text-gray-600 text-lg">Interactive tools to assess and improve your transfer pricing</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Risk Assessment Tool -->
        <a
          href={`${base}risk-assessment`}
          class="card hover:shadow-lg transition group"
        >
          <div class="flex items-center justify-center w-14 h-14 bg-navy-50 rounded-lg mb-6 group-hover:bg-gold-50 transition">
            <svg class="w-7 h-7 text-navy-700 group-hover:text-gold-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3 group-hover:text-gold-500 transition">
            Transfer Pricing Risk Assessment
          </h3>
          <p class="text-gray-600 mb-6">
            Free 5-minute assessment to evaluate your transfer pricing compliance risk. Get personalized recommendations based on your group structure and transactions.
          </p>
          <div class="text-sm font-semibold text-gold-500">
            Start Assessment →
          </div>
        </a>

        <!-- Benchmarking Guide -->
        <div class="card hover:shadow-lg transition group">
          <div class="flex items-center justify-center w-14 h-14 bg-navy-50 rounded-lg mb-6 group-hover:bg-gold-50 transition">
            <svg class="w-7 h-7 text-navy-700 group-hover:text-gold-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-navy-700 mb-3">
            Benchmarking Methodology Guide
          </h3>
          <p class="text-gray-600 mb-6">
            Learn which transfer pricing methodology is right for your business. Includes comparisons of TNMM, CUP, cost-plus, and other approaches.
          </p>
          <button
            onclick="alert('Guide available upon request. Contact us for more information.')"
            class="text-sm font-semibold text-gold-500"
          >
            Learn More →
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-700 mb-4">Transfer Pricing Basics</h2>
        <p class="text-gray-600 text-lg">Common questions about transfer pricing</p>
      </div>

      <div class="max-w-3xl mx-auto space-y-6">
        <!-- FAQ Item 1 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            What is transfer pricing?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4 leading-relaxed">
            Transfer pricing is the pricing of transactions between related entities within a multinational enterprise. It includes the pricing of goods, services, intellectual property, and financing arrangements between associated companies. Transfer pricing must comply with the arm's length principle, meaning prices should be set as if the parties were unrelated.
          </p>
        </details>

        <!-- FAQ Item 2 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            Why do I need transfer pricing documentation?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4 leading-relaxed">
            Transfer pricing documentation is required by the CRA to support your transfer pricing positions. Good documentation demonstrates that your pricing is commercially reasonable and complies with the arm's length principle. It's essential for CRA compliance, audit defense, and providing contemporaneous evidence of your transfer pricing analysis.
          </p>
        </details>

        <!-- FAQ Item 3 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            What's the difference between a local file and a master file?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4 leading-relaxed">
            A local file documents the transfer pricing analysis for specific transactions of a local entity. It's required annually for any entity with intercompany transactions. A master file documents the overall transfer pricing policies and structure of the multinational group. The master file provides context and the local file provides transaction-specific detail and benchmarking analysis.
          </p>
        </details>

        <!-- FAQ Item 4 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            What is the arm's length principle?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4 leading-relaxed">
            The arm's length principle requires that intercompany transactions be priced as if the parties were unrelated. It's the foundation of transfer pricing under OECD guidelines and Canadian tax law. This means the prices charged should be comparable to what independent entities would charge for similar transactions under similar circumstances.
          </p>
        </details>

        <!-- FAQ Item 5 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            How often do I need to update my transfer pricing documentation?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4 leading-relaxed">
            Transfer pricing documentation should be updated annually, in the fiscal year in which the transactions occur. However, if your business structure, functions, risks, or transactions haven't changed materially, you may be able to update your prior documentation rather than start from scratch. Documentation should be kept up-to-date and reflect current business operations.
          </p>
        </details>

        <!-- FAQ Item 6 -->
        <details class="bg-gray-50 p-6 rounded-lg cursor-pointer group">
          <summary class="flex items-center justify-between font-semibold text-navy-700 text-lg">
            What are transfer pricing penalties?
            <svg class="w-5 h-5 text-gold-500 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="text-gray-700 mt-4 leading-relaxed">
            The CRA can impose significant penalties for non-compliance with transfer pricing requirements, including penalties for lack of documentation (up to 10% of the adjustment) and penalties for misstatements (50%). These can substantially increase the cost of a transfer pricing adjustment. Proper documentation and compliance help protect against these penalties.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-padding bg-gradient-navy text-white">
    <div class="container-narrow text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">Need Professional Guidance?</h2>
      <p class="text-lg mb-8 text-gray-200">
        Our experts are ready to help with your transfer pricing questions and challenges.
      </p>
      <a href={`${base}contact`} class="btn-primary">Schedule a Consultation</a>
    </div>
  </section>
</BaseLayout>
