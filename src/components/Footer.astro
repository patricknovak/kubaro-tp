---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="gradient-navy text-white">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-gold-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-heading font-bold text-xl">K</span>
          </div>
          <div>
            <span class="font-heading font-bold text-lg block">Kubaro</span>
            <span class="text-gold-400 text-xs font-medium tracking-wider uppercase">Transfer Pricing</span>
          </div>
        </div>
        <p class="text-gray-300 text-sm leading-relaxed">
          AI-powered transfer pricing advisory for Canadian and cross-border businesses.
          20 years of expertise, delivered with modern efficiency.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold text-gold-400 mb-4 text-sm uppercase tracking-wider">Services</h4>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href={`${base}services/#documentation`} class="hover:text-white transition-colors">TP Documentation</a></li>
          <li><a href={`${base}services/#benchmarking`} class="hover:text-white transition-colors">Benchmarking Studies</a></li>
          <li><a href={`${base}services/#audit-defense`} class="hover:text-white transition-colors">CRA Audit Defense</a></li>
          <li><a href={`${base}services/#policy`} class="hover:text-white transition-colors">Policy Design</a></li>
          <li><a href={`${base}services/#pillar-two`} class="hover:text-white transition-colors">Pillar Two Advisory</a></li>
          <li><a href={`${base}services/#apa`} class="hover:text-white transition-colors">APA Support</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-semibold text-gold-400 mb-4 text-sm uppercase tracking-wider">Resources</h4>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href={`${base}blog/`} class="hover:text-white transition-colors">Insights & Articles</a></li>
          <li><a href={`${base}resources/`} class="hover:text-white transition-colors">Free Downloads</a></li>
          <li><a href={`${base}risk-assessment/`} class="hover:text-white transition-colors">TP Risk Assessment</a></li>
          <li><a href={`${base}resources/#newsletter`} class="hover:text-white transition-colors">Newsletter</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-gold-400 mb-4 text-sm uppercase tracking-wider">Get in Touch</h4>
        <ul class="space-y-2 text-sm text-gray-300">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:info@kubarotp.ca" class="hover:text-white transition-colors">info@kubarotp.ca</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span>1-800-KUBARO-TP</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Toronto, ON | Vancouver, BC</span>
          </li>
        </ul>
        <div class="flex gap-3 mt-4">
          <a href="#" class="w-8 h-8 bg-navy-600 rounded-full flex items-center justify-center hover:bg-gold-500 transition-colors" aria-label="LinkedIn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="w-8 h-8 bg-navy-600 rounded-full flex items-center justify-center hover:bg-gold-500 transition-colors" aria-label="Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-navy-600 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-400 text-sm">&copy; {year} Kubaro Transfer Pricing Advisory. All rights reserved.</p>
      <div class="flex gap-6 text-sm text-gray-400">
        <a href={`${base}privacy/`} class="hover:text-white transition-colors">Privacy Policy</a>
        <a href={`${base}terms/`} class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
