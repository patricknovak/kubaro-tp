---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}about/`, label: 'About' },
  { href: `${base}services/`, label: 'Services' },
  { href: `${base}pricing/`, label: 'Pricing' },
  { href: `${base}blog/`, label: 'Insights' },
  { href: `${base}resources/`, label: 'Resources' },
  { href: `${base}risk-assessment/`, label: 'TP Risk Check' },
  { href: `${base}contact/`, label: 'Contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100" id="main-nav">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href={base} class="flex items-center gap-2 group">
        <div class="w-10 h-10 bg-navy-700 rounded-lg flex items-center justify-center">
          <span class="text-gold-400 font-heading font-bold text-xl">K</span>
        </div>
        <div class="hidden sm:block">
          <span class="text-navy-700 font-heading font-bold text-lg leading-tight block">Kubaro</span>
          <span class="text-gold-500 text-xs font-medium tracking-wider uppercase">Transfer Pricing</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-md transition-colors',
              currentPath === link.href || (link.href !== base && currentPath.startsWith(link.href))
                ? 'text-gold-600 bg-gold-50'
                : 'text-gray-600 hover:text-navy-700 hover:bg-gray-50'
            ]}
          >
            {link.label}
          </a>
        ))}
        <a href={`${base}contact/`} class="ml-3 btn-primary text-sm !py-2 !px-4">
          Book a Call
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-toggle" class="lg:hidden p-2 text-gray-600 hover:text-navy-700" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-3 space-y-1">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-3 py-2 rounded-md text-sm font-medium',
            currentPath === link.href
              ? 'text-gold-600 bg-gold-50'
              : 'text-gray-600 hover:text-navy-700 hover:bg-gray-50'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href={`${base}contact/`} class="block btn-primary text-sm text-center mt-3">
        Book a Call
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
