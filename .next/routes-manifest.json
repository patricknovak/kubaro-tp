{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "/wc-con-platform",
  "redirects": [
    {
      "source": "/wc-con-platform/",
      "destination": "/wc-con-platform",
      "basePath": false,
      "internal": true,
      "statusCode": 308,
      "regex": "^/wc-con-platform/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/calculator",
      "regex": "^/calculator(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/calculator(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/hub",
      "regex": "^/hub(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/hub(?:/)?$"
    },
    {
      "page": "/hub/submit",
      "regex": "^/hub/submit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/hub/submit(?:/)?$"
    },
    {
      "page": "/opportunities",
      "regex": "^/opportunities(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/opportunities(?:/)?$"
    },
    {
      "page": "/projects",
      "regex": "^/projects(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projects(?:/)?$"
    },
    {
      "page": "/quote",
      "regex": "^/quote(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/quote(?:/)?$"
    },
    {
      "page": "/services",
      "regex": "^/services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/services(?:/)?$"
    },
    {
      "page": "/services/aggregate-sales",
      "regex": "^/services/aggregate\\-sales(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/services/aggregate\\-sales(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}